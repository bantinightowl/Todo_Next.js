# MongoDB Configuration
# For MongoDB Atlas (recommended for production):
# mongodb+srv://<username>:<password>@cluster.mongodb.net/myapp
MONGODB_URI=mongodb://localhost:27017/myapp

# NextAuth Configuration
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-change-this-in-production-min-32-chars
NEXTAUTH_URL=https://your-domain.com

# Session Configuration (30 days in seconds)
NEXTAUTH_SESSION_MAX_AGE=2592000

# Application URL (your production domain)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Server Port (for Docker/containerized deployments)
PORT=3000

# Node Environment
NODE_ENV=production
